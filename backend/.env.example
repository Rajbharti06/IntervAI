# ─── IntervAI Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in values you want to use server-side.
# API keys can also be supplied per-session via the Setup UI (they're never stored).

# Server
APP_ENV=development          # development | production
LOG_LEVEL=info

# Optional: pre-configure a provider key so the backend can call the LLM
# directly without requiring users to enter their own key each session.
# Leave blank if users will supply their own keys through the UI.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=
NVIDIA_API_KEY=

# CORS — comma-separated origins (default allows all in dev)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis (optional — for production session persistence)
# If not set, sessions are stored in memory (resets on restart).
REDIS_URL=
